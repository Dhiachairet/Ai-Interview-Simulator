# Base URL of your deployed backend API (Railway). No trailing slash.
# Injected at BUILD time by Vite, so it must be set in the Vercel project settings.
VITE_API_URL=https://your-backend.up.railway.app

# Vapi public (web) key for the in-browser voice interview.
VITE_VAPI_PUBLIC_KEY=your-vapi-public-key
