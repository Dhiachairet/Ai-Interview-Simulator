# ───────────── Server ─────────────
# Railway provides PORT automatically. Locally this defaults to 5000.
PORT=5000

# ───────────── Database (REQUIRED) ─────────────
# MongoDB Atlas connection string (Database > Connect > Drivers).
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai-interview?retryWrites=true&w=majority

# ───────────── Auth (REQUIRED) ─────────────
# Use a long, random string (e.g. `openssl rand -base64 48`).
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=30d

# ───────────── Frontend origin (REQUIRED in production) ─────────────
# Your deployed Vercel URL. Used for CORS and Google OAuth redirects. No trailing slash.
FRONTEND_URL=https://your-frontend.vercel.app

# ───────────── Google OAuth (optional — only if Google login is used) ─────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match the deployed backend callback URL registered in Google Cloud Console.
GOOGLE_CALLBACK_URL=https://your-backend.up.railway.app/api/auth/google/callback

# ───────────── AI & Voice ─────────────
# Gemini powers answer evaluation and CV parsing (required for those features).
GEMINI_API_KEY=your-gemini-api-key
# Vapi private key — used server-side to fetch call transcripts.
VAPI_PRIVATE_KEY=your-vapi-private-key
# ElevenLabs TTS (optional — legacy text interview voice).
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ───────────── Cloudinary (optional — stores uploaded resume files) ─────────────
# If omitted, resumes are still parsed; only the original file is not stored.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
